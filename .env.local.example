EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
# Paystack public keys. App.tsx picks between these automatically based on
# __DEV__ (true in Expo Go / dev client, false in a real release build) — a
# local `expo start` session always uses the TEST key below, and only a real
# production build ever uses the live key. You do not need to change any
# code to switch; just make sure both are set.
# Live "pk_live_..." key, from the Paystack dashboard (Settings > API Keys
# & Webhooks). Only ever used in production builds — real customer charges.
EXPO_PUBLIC_PAYSTACK_KEY=
# Sandbox "pk_test_..." key, same dashboard. Used in every non-production
# (__DEV__) run so you can test payments without moving real money.
EXPO_PUBLIC_PAYSTACK_TEST_KEY=
# NOTE: the AI Trash Estimator (Groq/NVIDIA/Claude) and voice transcription
# (Gemini) provider keys used to live here as EXPO_PUBLIC_* vars, which
# ships them inside the compiled app for anyone to extract. They now live
# server-side only, as edge function secrets, never sent to the client:
#   supabase secrets set GROQ_API_KEY=... ANTHROPIC_API_KEY=... \
#     NVIDIA_API_KEY=... GEMINI_API_KEY=...
# For local development against `supabase functions serve`, put the same
# four vars (without the EXPO_PUBLIC_ prefix) in supabase/functions/.env
# (gitignored) instead — see supabase/functions/ai-trash-estimate/index.ts
# and supabase/functions/voice-transcribe/index.ts for what each expects.

# Map provider (services/maps/) — which provider activeMapProvider resolves
# to. One of: mapbox | osm | google. Defaults to "mapbox" if unset.
EXPO_PUBLIC_MAP_PROVIDER=

# Mapbox public token (get one at account.mapbox.com — a "pk." public token,
# not a secret token). Only required when EXPO_PUBLIC_MAP_PROVIDER=mapbox.
EXPO_PUBLIC_MAPBOX_TOKEN=

# NOTE: the native @rnmapbox/maps download token (RNMAPBOX_DOWNLOAD_TOKEN)
# is a separate, build-time-only secret and does NOT go here — it must be
# set as an EAS secret instead:
#   eas secret:create --scope project --name RNMAPBOX_DOWNLOAD_TOKEN --value <your-mapbox-secret-token> --type string
# See app.config.js for where it's consumed.

# Sentry crash/error reporting DSN (get one at sentry.io — Settings > Projects
# > <project> > Client Keys (DSN)). See lib/sentry.ts and index.ts.
EXPO_PUBLIC_SENTRY_DSN=
