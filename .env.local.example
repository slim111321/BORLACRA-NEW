EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
# Paystack Keys
EXPO_PUBLIC_PAYSTACK_KEY=
EXPO_PUBLIC_PAYSTACK_TEST_KEY=
# Anthropic (Claude) API key — get one at console.anthropic.com. This is
# separate from a claude.ai Pro subscription; API usage is billed
# separately (pay-per-token). Powers the AI Trash Estimator.
EXPO_PUBLIC_ANTHROPIC_API_KEY=

# NVIDIA (build.nvidia.com) API key — active AI Trash Estimator provider
# (Mistral Medium 3.5 128B) until a real Anthropic key is added.
EXPO_PUBLIC_NVIDIA_API_KEY=

# Groq AI Key — fallback for the AI Trash Estimator if the above fail
EXPO_PUBLIC_GROQ_API_KEY=

# Map provider (services/maps/) — which provider activeMapProvider resolves
# to. One of: mapbox | osm | google. Defaults to "mapbox" if unset.
EXPO_PUBLIC_MAP_PROVIDER=

# Mapbox public token (get one at account.mapbox.com — a "pk." public token,
# not a secret token). Only required when EXPO_PUBLIC_MAP_PROVIDER=mapbox.
EXPO_PUBLIC_MAPBOX_TOKEN=

# NOTE: the native @rnmapbox/maps download token (RNMAPBOX_DOWNLOAD_TOKEN)
# is a separate, build-time-only secret and does NOT go here — it must be
# set as an EAS secret instead:
#   eas secret:create --scope project --name RNMAPBOX_DOWNLOAD_TOKEN --value <your-mapbox-secret-token> --type string
# See app.config.js for where it's consumed.
