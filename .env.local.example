EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
# Paystack Keys
EXPO_PUBLIC_PAYSTACK_KEY=
EXPO_PUBLIC_PAYSTACK_TEST_KEY=
# Anthropic (Claude) API key — get one at console.anthropic.com. This is
# separate from a claude.ai Pro subscription; API usage is billed
# separately (pay-per-token). Powers the AI Trash Estimator.
EXPO_PUBLIC_ANTHROPIC_API_KEY=

# NVIDIA (build.nvidia.com) API key — active AI Trash Estimator provider
# (Mistral Medium 3.5 128B) until a real Anthropic key is added.
EXPO_PUBLIC_NVIDIA_API_KEY=

# Groq AI Key — fallback for the AI Trash Estimator if the above fail
EXPO_PUBLIC_GROQ_API_KEY=
