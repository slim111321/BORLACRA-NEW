VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Map provider (src/services/maps/) — which provider activeMapProvider
# resolves to, and which live-map widget (Leaflet vs Mapbox) renders on the
# Live Ops tab. One of: mapbox | osm | google. Defaults to "mapbox" if unset.
VITE_MAP_PROVIDER=

# Mapbox public token (get one at account.mapbox.com — a "pk." public
# token). Only required when VITE_MAP_PROVIDER=mapbox.
VITE_MAPBOX_TOKEN=
